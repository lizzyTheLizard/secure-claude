{
  "name": "secure-claude",
  "version": "1.1.1",
  "description": "Runs Claude Code in a sandboxed Docker environment with HTTP proxy filtering",
  "type": "module",
  "bin": {
    "secure-claude": "./dist/bin/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "prepare": "pnpm run build",
    "lint": "eslint .",
    "start": "node dist/bin/index.js",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "check-release": "node scripts/check-release.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "hono": "^4.11.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lizzyTheLizard/secure-claude.git"
  },
  "packageManager": "pnpm@10.33.2"
}
